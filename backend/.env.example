# Port the Express server listens on
PORT=4000

# Exact origin (scheme + host + port) the frontend dev server runs on.
# Vite's default is http://localhost:5173 — change this only if you changed
# the frontend's port too. This must match EXACTLY or you'll get CORS errors.
FRONTEND_ORIGIN=http://localhost:5173

# How long search results are cached in memory before re-hitting the
# upstream APIs, in milliseconds. 30 minutes by default.
CACHE_TTL_MS=1800000
